# CommerceGov Contacts — local environment (placeholder values only)
APP_HOST=127.0.0.1
PORT=8025
DATABASE_PATH=./leads.db
MAX_PASTE_CHARS=200000
LOG_LEVEL=INFO

LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_TIMEOUT=60

# Optional PostgreSQL (Phase 1+). When set, the web app uses PostgreSQL instead of SQLite.
DATABASE_URL=postgresql://user:password@localhost:5432/contacts

# Isolated database for PostgreSQL integration tests (must be disposable).
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/contacts_test
